diff --git a/user/trace.c b/user/trace.c
new file mode 100644
--- /dev/null
+++ b/user/trace.c
@@ -0,0 +1,24 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[])
+{
+  int mask;
+
+  if(argc < 3){
+    fprintf(2, "usage: trace mask command\n");
+    exit(1);
+  }
+
+  mask = atoi(argv[1]);
+  trace(mask);
+  exec(argv[2], &argv[2]);
+
+  printf("trace: exec failed\n");
+  exit(0);
+}

diff --git a/user/procinfo.c b/user/procinfo.c
new file mode 100644
--- /dev/null
+++ b/user/procinfo.c
@@ -0,0 +1,23 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "kernel/procinfo.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[])
+{
+  struct procinfo info;
+
+  if(procinfo(1, &info) < 0){
+    printf("procinfo failed\n");
+    exit(1);
+  }
+
+  printf("PID: %d\n", info.pid);
+  printf("PPID: %d\n", info.ppid);
+  printf("State: %d\n", info.state);
+  printf("Memory: %ld bytes\n", info.sz);
+  printf("Name: %s\n", info.name);
+
+  exit(0);
+}
