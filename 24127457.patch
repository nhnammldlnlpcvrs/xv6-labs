diff --git a/kernel/sysproc.c b/kernel/sysproc.c
index 3b4d5bd..b9a58ef 100644
--- a/kernel/sysproc.c
+++ b/kernel/sysproc.c
@@
+#include "procinfo.h"
+extern struct proc proc[NPROC];

+uint64
+sys_trace(void)
+{
+  int mask;
+  argint(0, &mask);
+  myproc()->tracemask = mask;
+  return 0;
+}

+uint64
+sys_procinfo(void)
+{
+  int pid;
+  uint64 addr;
+  struct proc *p;
+  struct procinfo info;
+
+  argint(0, &pid);
+  argaddr(1, &addr);
+
+  for(p = proc; p < &proc[NPROC]; p++){
+    if(p->pid == pid){
+      info.pid = p->pid;
+      info.ppid = p->parent ? p->parent->pid : 0;
+      info.state = p->state;
+      info.sz = p->sz;
+
+      safestrcpy(info.name, p->name, sizeof(info.name));
+
+      if(copyout(myproc()->pagetable, addr,
+                 (char *)&info, sizeof(info)) < 0)
+        return -1;
+
+      return 0;
+    }
+  }
+  return -1;
+}

